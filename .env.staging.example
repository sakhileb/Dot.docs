APP_NAME=Dot.docs
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_URL=https://staging.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dot_docs_staging
DB_USERNAME=dot_docs
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.example.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="${APP_NAME}"

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
AI_RATE_LIMIT_PER_MINUTE=20
AI_CACHE_TTL_MINUTES=60
AI_QUEUE_NAME=ai

BACKUP_DISK=local
BACKUP_PATH=backups
BACKUP_KEEP_DAYS=14

DATA_PROTECTION_DISK=local
DATA_EXPORT_PATH=exports

TELESCOPE_ENABLED=true
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
PLAUSIBLE_DOMAIN=
PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js
GOOGLE_ANALYTICS_MEASUREMENT_ID=
ANALYTICS_ENABLED=true
ANALYTICS_PROVIDER=plausible
ANALYTICS_DASHBOARD_REFRESH_SECONDS=60
WEBHOOKS_ENABLED=true
WEBHOOKS_TIMEOUT_SECONDS=10

SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=
DISCORD_WEBHOOK_URL=
GOOGLE_DRIVE_ACCESS_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=
DROPBOX_ACCESS_TOKEN=
DROPBOX_FOLDER_PATH=/DotDocs
ONEDRIVE_ACCESS_TOKEN=
ONEDRIVE_FOLDER_PATH=DotDocs

